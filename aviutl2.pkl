amends
  "https://raw.githubusercontent.com/sevenc-nanashi/aviutl2-cli/feat/pkl/src/AviUtl2CliConfig.pkl"

project {
  id = "sevenc-nanashi.bpm_object-aux2"
  name = "bpm_object.aux2"
  version = "0.1.0"
}

development {
  aviutl2_version = "latest"
  catalog_dependencies = List("KuroNeko.CopyAlias")
}

artifacts {
  ["bpm_object-aux2"] {
    destination = "Plugin/bpm_object_aux2.aux2"

    profiles {
      ["debug"] {
        build = "cargo build"
        source = "target/debug/bpm_object_aux2.dll"
      }

      ["release"] {
        build = "cargo build --release"
        source = "target/release/bpm_object_aux2.dll"
      }
    }
  }
}

catalog {
  id = "sevenc-nanashi.bpm_object-aux2"
  license_path = "LICENSE"
  download_repo {
    owner = "sevenc-nanashi"
    repo = "bpm_object-aux2"
  }
}
